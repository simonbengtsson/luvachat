{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "luvachat",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.tsx",
  "durable_objects": {
    "bindings": [
      {
        "name": "SyncObject",
        "class_name": "SyncObject",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SyncObject"],
    },
  ],
  "observability": {
    "enabled": true,
  },
}
